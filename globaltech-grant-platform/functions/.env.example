# Copy this to functions/.env (NOT committed — already in .gitignore) and fill in real values.
# firebase-functions v2's defineString() params are read from this file at deploy time.

# The Google Sheet ID from its URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_IS_THE_ID/edit
ONBOARDING_SHEET_ID=

# A Google Cloud service account with read access to the sheet (share the sheet with this email)
GOOGLE_SHEETS_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=

# ---- Phase 3 (not needed yet) ----
# RESEND_API_KEY=
# APPLICATIONS_BACKUP_SHEET_ID=
