# ---- Firebase client config (Project settings > General > Your apps > Web app) ----
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---- Firebase Admin (server-side) ----
# Generate a service account key: Project settings > Service accounts > Generate new private key
# Paste the whole JSON on one line (escape newlines in the private_key with \n), e.g.:
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"-----BEGIN...\n...","client_email":"..."}
FIREBASE_SERVICE_ACCOUNT_KEY=

# ---- App URL (used to build the /apply/[token] links shown in the admin staff page) ----
NEXT_PUBLIC_APP_URL=https://grant.globaltech.com

# ---- Onboarding sheet sync (Phase 1 — runs in this app, not Firebase Functions) ----
# The Google Sheet ID from its URL: https://docs.google.com/spreadsheets/d/THIS_PART/edit
ONBOARDING_SHEET_ID=
# A Google Cloud service account with read access to the sheet (share the sheet with this email)
GOOGLE_SHEETS_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=

# Shared secret for the /api/cron/sync-staff route, so only Vercel's own Cron
# Job can trigger it (not required if you only ever use the "Sync now" button)
CRON_SECRET=

# ---- Phase 3 (not needed yet — fill in once Phase 3 starts) ----
# RESEND_API_KEY=
# APPLICATIONS_BACKUP_SHEET_ID=
